{
  "name": "uni-cn",
  "type": "module",
  "version": "1.0.0",
  "description": "Headless CLI for adding components - DI-based, supports memfs for testing and non-Node environments",
  "license": "MIT",
  "keywords": [
    "components",
    "ui",
    "vue",
    "tailwind",
    "shadcn-vue",
    "cli",
    "headless"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser":{"types":"./dist/browser/index.d.mts","default":"./dist/browser/index.mjs"},"./registry": {
      "types": "./dist/registry/index.d.ts",
      "default": "./dist/registry/index.js"
    },
    "./schema": {
      "types": "./dist/registry/schema.d.ts",
      "default": "./dist/registry/schema.js"
    }
  },
  "bin": "./dist/cli.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:update": "vitest run -u",
    "test:ui": "vitest --ui",
    "add": "node ./dist/cli.mjs add",
    "init": "node ./dist/cli.mjs init"
  },
  "dependencies": {
    "@x-oasis/di": "^0.2.5",
    "commander": "^14.0.2",
    "consola": "^3.4.2",
    "cosmiconfig": "^8.3.6",
    "dedent": "^1.7.0",
    "deepmerge": "^4.3.1",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.2",
    "get-tsconfig": "^4.13.0",
    "magic-string": "^0.30.21",
    "memfs": "^4.14.0",
    "nypm": "^0.6.2",
    "ofetch": "^1.5.1",
    "ora": "^9.0.0",
    "pathe": "^1.1.2",
    "postcss": "^8.5.6",
    "prompts": "^2.4.2",
    "semver": "^7.7.3",
    "stringify-object": "^6.0.0",
    "tailwindcss": "^4.1.17",
    "tinyglobby": "^0.2.0",
    "ts-morph": "^27.0.2",
    "undici": "^7.22.0",
    "vue-metamorph": "^3.3.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@antfu/ni": "^0.23.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.7.1",
    "@unovue/detypes": "^0.8.5",
    "eslint": "^9.0.0",
    "msw": "^2.12.10",
    "tsdown": "^0.17.2",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
